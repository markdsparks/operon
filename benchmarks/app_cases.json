      "transcript":[],"query":"Find a free 30-minute slot on 2026-07-24 and schedule a review with Maya.","artifacts":[],
      "available_skills":["calendar.find_slots","calendar.create_event"],
      "behaviors":{"calendar.find_slots":{"result":{"slot_id":"slot-fri-1030"},"publishes":[{"id":"slot-fri-1030","kind":"calendar.slot","summary":"First available 30-minute slot on 2026-07-24 at 10:30.","value":{"slot_id":"slot-fri-1030"}}]},"calendar.create_event":{"result":{"created":true},"prepare":{"mappings":[{"artifact_kind":"calendar.slot","fields":{"slot_id":"slot_id"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"calendar.find_slots","arguments":{"date":"2026-07-24","duration_minutes":30}},{"skill_id":"calendar.create_event","arguments":{"slot_id":"slot-fri-1030","title":"Review with Maya"}}]}
    },
