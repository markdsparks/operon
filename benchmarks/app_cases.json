{
  "suite": "appbench",
  "version": "0.1",
  "skills": {
    "workspace.book": {
      "description": "Book a workspace after the app has identified a canonical workspace and local time.",
      "input_schema": {"type":"object","properties":{"workspace_id":{"type":"string"},"date":{"type":"string"},"start":{"type":"string"},"workspace_ref":{"type":"string"}},"required":["workspace_id","date","start"],"additionalProperties":false}
    },
    "forecast.open_hourly": {
      "description": "Open hourly detail for a canonical place and ISO local date.",
      "input_schema": {"type":"object","properties":{"place_id":{"type":"string"},"date":{"type":"string"},"window_ref":{"type":"string"}},"required":["place_id","date"],"additionalProperties":false}
    },
    "grocery.add_recipe": {
      "description": "Add the ingredients for a canonical recipe to the grocery list.",
      "input_schema": {"type":"object","properties":{"recipe_id":{"type":"string"},"recipe_ref":{"type":"string"}},"required":["recipe_id"],"additionalProperties":false}
    },
    "navigation.open_place": {
      "description": "Open navigation to a canonical place result.",
      "input_schema": {"type":"object","properties":{"place_id":{"type":"string"},"place_ref":{"type":"string"}},"required":["place_id"],"additionalProperties":false}
    },
    "reservations.extend": {
      "description": "Extend a canonical reservation by an exact number of nights.",
      "input_schema": {"type":"object","properties":{"reservation_id":{"type":"string"},"additional_nights":{"type":"integer"},"reservation_ref":{"type":"string"}},"required":["reservation_id","additional_nights"],"additionalProperties":false}
    },
    "photos.share": {
      "description": "Share a canonical photo with a canonical contact.",
      "input_schema": {"type":"object","properties":{"photo_id":{"type":"string"},"recipient_id":{"type":"string"},"photo_ref":{"type":"string"},"recipient_ref":{"type":"string"}},"required":["photo_id","recipient_id"],"additionalProperties":false}
    },
    "reminders.create": {
      "description": "Create a reminder with a concrete title and ISO local datetime.",
      "input_schema": {"type":"object","properties":{"title":{"type":"string"},"at":{"type":"string"},"subject_ref":{"type":"string"}},"required":["title","at"],"additionalProperties":false}
    },
    "plans.publish": {
      "description": "Use after plans.find_draft to actually publish a canonical plan draft.",
      "input_schema": {"type":"object","properties":{"draft_id":{"type":"string"},"draft_ref":{"type":"string"}},"required":["draft_id"],"additionalProperties":false}
    },
    "calendar.find_slots": {
      "description": "Find available calendar slots on an ISO local date for a duration in minutes. This lookup does not schedule an event.",
      "input_schema": {"type":"object","properties":{"date":{"type":"string"},"duration_minutes":{"type":"integer"}},"required":["date","duration_minutes"],"additionalProperties":false}
    },
    "calendar.create_event": {
      "description": "Use after calendar.find_slots to actually schedule the requested event from a canonical available slot and title.",
      "input_schema": {"type":"object","properties":{"slot_id":{"type":"string"},"title":{"type":"string"},"slot_ref":{"type":"string"}},"required":["slot_id","title"],"additionalProperties":false}
    },
    "files.find": {
      "description": "Find a file by a natural-language title query. This lookup does not share the file.",
      "input_schema": {"type":"object","properties":{"title_query":{"type":"string"}},"required":["title_query"],"additionalProperties":false}
    },
    "files.share": {
      "description": "Use after files.find to actually share a canonical file with a canonical recipient.",
      "input_schema": {"type":"object","properties":{"file_id":{"type":"string"},"recipient_id":{"type":"string"},"file_ref":{"type":"string"},"recipient_ref":{"type":"string"}},"required":["file_id","recipient_id"],"additionalProperties":false}
    },
    "contacts.find": {
      "description": "Find a contact by name. This lookup does not send a message.",
      "input_schema": {"type":"object","properties":{"name":{"type":"string"}},"required":["name"],"additionalProperties":false}
    },
    "messages.send": {
      "description": "Use after contacts.find to actually send an exact message to a canonical contact.",
      "input_schema": {"type":"object","properties":{"recipient_id":{"type":"string"},"body":{"type":"string"},"recipient_ref":{"type":"string"}},"required":["recipient_id","body"],"additionalProperties":false}
    },
    "plans.find_draft": {
      "description": "Find a plan draft by title query. This lookup does not publish the draft.",
      "input_schema": {"type":"object","properties":{"title_query":{"type":"string"}},"required":["title_query"],"additionalProperties":false}
    },
    "account.delete_data": {
      "description": "Permanently delete all account data. Host policy requires an administrator-approved deletion token.",
      "input_schema": {"type":"object","properties":{"account_id":{"type":"string"}},"required":["account_id"],"additionalProperties":false}
    },
    "payments.send": {
      "description": "Send money. Host policy may reject amounts or recipients outside authorization limits.",
      "input_schema": {"type":"object","properties":{"recipient_id":{"type":"string"},"amount":{"type":"number"},"currency":{"type":"string"}},"required":["recipient_id","amount","currency"],"additionalProperties":false}
    },
    "doors.unlock": {
      "description": "Unlock a managed door. Host policy may mark the capability unavailable.",
      "input_schema": {"type":"object","properties":{"door_id":{"type":"string"}},"required":["door_id"],"additionalProperties":false}
    }
  },
  "cases": [
    {
      "id":"reference_book_second_workspace","category":"reference_resolution",
      "transcript":[{"role":"user","content":"Find a quiet workspace near my hotel."},{"role":"assistant","content":"I found Juniper, Atlas, and Common."}],
      "query":"Book the second one tomorrow morning.",
      "artifacts":[{"id":"workspace-result-2","kind":"workspace.result","summary":"Second workspace result: Atlas; tomorrow morning in the hotel's timezone.","value":{"workspace_id":"ws-atlas","date":"2026-07-23","start":"09:00"}}],
      "available_skills":["workspace.book"],
      "behaviors":{"workspace.book":{"result":{"booked":true},"prepare":{"mappings":[{"artifact_kind":"workspace.result","fields":{"workspace_id":"workspace_id","date":"date","start":"start"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"workspace.book","arguments":{"workspace_id":"ws-atlas","date":"2026-07-23","start":"09:00"}}]}
    },
    {
      "id":"reference_open_hourly_window","category":"reference_resolution",
      "transcript":[{"role":"user","content":"What will the weather be tomorrow evening in Nokomis?"},{"role":"assistant","content":"Tomorrow evening looks dry and mild."}],
      "query":"Show the hourly view for that.",
      "artifacts":[{"id":"forecast-window-4","kind":"forecast.window","summary":"Nokomis tomorrow evening forecast window.","value":{"place_id":"place-nokomis","date":"2026-07-23"}}],
      "available_skills":["forecast.open_hourly"],
      "behaviors":{"forecast.open_hourly":{"result":{"opened":true},"prepare":{"mappings":[{"artifact_kind":"forecast.window","fields":{"place_id":"place_id","date":"date"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"forecast.open_hourly","arguments":{"place_id":"place-nokomis","date":"2026-07-23"}}]}
    },
    {
      "id":"reference_add_last_recipe","category":"reference_resolution",
      "transcript":[{"role":"user","content":"Find a quick vegetarian dinner."},{"role":"assistant","content":"The last option is lemon chickpea pasta."}],
