      "artifacts":[{"id":"recipe-7","kind":"recipe.selection","summary":"Selected lemon chickpea pasta recipe.","value":{"recipe_id":"recipe-lemon-chickpea"}}],
      "available_skills":["grocery.add_recipe"],
      "behaviors":{"grocery.add_recipe":{"result":{"added":true},"prepare":{"mappings":[{"artifact_kind":"recipe.selection","fields":{"recipe_id":"recipe_id"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"grocery.add_recipe","arguments":{"recipe_id":"recipe-lemon-chickpea"}}]}
    },
    {
      "id":"reference_navigate_second_place","category":"reference_resolution",
      "transcript":[{"role":"user","content":"Show coffee shops near the station."},{"role":"assistant","content":"I found North Loop, Ember, and Canteen."}],
      "query":"Navigate to the second place.",
      "artifacts":[{"id":"place-result-2","kind":"place.result","summary":"Second place result: Ember Coffee.","value":{"place_id":"place-ember"}}],
      "available_skills":["navigation.open_place"],
      "behaviors":{"navigation.open_place":{"result":{"opened":true},"prepare":{"mappings":[{"artifact_kind":"place.result","fields":{"place_id":"place_id"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"navigation.open_place","arguments":{"place_id":"place-ember"}}]}
    },
    {
      "id":"prepare_extend_same_reservation","category":"argument_preparation",
      "transcript":[{"role":"user","content":"Open my Portland hotel reservation."},{"role":"assistant","content":"The Alder reservation is open."}],
      "query":"Extend the same reservation by two nights.",
      "artifacts":[{"id":"reservation-current","kind":"reservation.current","summary":"Current Alder Hotel reservation.","value":{"reservation_id":"res-alder-884"}}],
      "available_skills":["reservations.extend"],
      "behaviors":{"reservations.extend":{"result":{"extended":true},"prepare":{"mappings":[{"artifact_kind":"reservation.current","fields":{"reservation_id":"reservation_id"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"reservations.extend","arguments":{"reservation_id":"res-alder-884","additional_nights":2}}]}
