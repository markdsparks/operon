    {
      "id":"prepare_share_photo_with_contact","category":"argument_preparation",
      "transcript":[{"role":"user","content":"Open the sunset photo and Maya's contact."},{"role":"assistant","content":"Both are selected."}],
      "query":"Send that photo to Maya.",
      "artifacts":[{"id":"photo-current","kind":"photo.current","summary":"Selected sunset photo.","value":{"photo_id":"photo-sunset-19"}},{"id":"contact-maya","kind":"contact.current","summary":"Selected contact Maya Chen.","value":{"recipient_id":"contact-maya-chen"}}],
      "available_skills":["photos.share"],
      "behaviors":{"photos.share":{"result":{"shared":true},"prepare":{"mappings":[{"artifact_kind":"photo.current","fields":{"photo_id":"photo_id"}},{"artifact_kind":"contact.current","fields":{"recipient_id":"recipient_id"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"photos.share","arguments":{"photo_id":"photo-sunset-19","recipient_id":"contact-maya-chen"}}]}
    },
