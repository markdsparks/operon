      "available_skills":["reminders.create"],
      "behaviors":{"reminders.create":{"result":{"created":true},"prepare":{"mappings":[{"artifact_kind":"document.current","fields":{"title":"title"}}]}}},
      "expected":{"outcome":"completed","calls":[{"skill_id":"reminders.create","arguments":{"title":"Review quarterly risk report","at":"2026-07-22T16:00:00-05:00"}}]}
    },
    {
