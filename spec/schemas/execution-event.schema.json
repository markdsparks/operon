{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operon.dev/spec/0.1/execution-event.schema.json",
  "title": "Operon execution event",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "kind": { "const": "generation_completed" },
        "protocol_version": { "const": "0.1" },
        "request_id": { "type": "integer", "minimum": 1 },
        "response": { "type": "object" }
      },
      "required": ["kind", "protocol_version", "request_id", "response"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "const": "retrieval_completed" },
        "protocol_version": { "const": "0.1" },
        "request_id": { "type": "integer", "minimum": 1 },
        "sources": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["kind", "protocol_version", "request_id", "sources"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "const": "memory_search_completed" },
        "protocol_version": { "const": "0.1" },
        "request_id": { "type": "integer", "minimum": 1 },
        "records": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["kind", "protocol_version", "request_id", "records"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "const": "output_validated" },
        "protocol_version": { "const": "0.1" },
        "request_id": { "type": "integer", "minimum": 1 },
        "errors": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["kind", "protocol_version", "request_id", "errors"],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "kind": { "const": "command_failed" },
        "protocol_version": { "const": "0.1" },
        "request_id": { "type": "integer", "minimum": 1 },
        "failure": {
          "enum": ["provider", "grounding", "memory", "cancelled", "timeout"]
        },
        "message": { "type": "string" }
      },
      "required": ["kind", "protocol_version", "request_id", "failure", "message"],
      "additionalProperties": false
    }
  ]
}
